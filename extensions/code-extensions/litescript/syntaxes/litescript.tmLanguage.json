{
    "scopeName": "source.litescript",
    "patterns": [
        {
            "name": "keyword.control.litescript",
            "match": "\\b(conditional|loop|return|exit|start|import|require)\\b"
        },
        {
            "name": "comment.line.litescript",
            "match": "\\$.*$"
        },
        {
            "name": "constant.numeric.litescript",
            "match": "\\b\\d+(?:\\.\\d+)?\\b"
        },
        {
            "name": "keyword.operator.litescript",
            "match": "(\\|\\||&&|\\||\\^|&|=|\\+=|-=|==|!=|<=|<|>=|>|<<|>>|\\+|-|\\*\\*|\\*|/|%|!|~)"
        },
        {
            "name": "string.quoted.double.litescript",
            "begin": "\"",
            "end": "\""
        },
        {
            "name": "storage.type.litescript",
            "match": "\\b(container|global)\\b"
        },
        {
            "name": "entity.name.function.container.litescript",
            "match": "\\b(get|put|equ|del|top|end|psh|pop|deq|num|igtk|igtv)\\b"
        },
        {
            "name": "entity.name.function.declaration.litescript",
            "match": "^(?!\t).*$"
        },
        {
            "name": "entity.name.function.invocation.litescript",
            "match": "\\b\\w+:"
        },
        {
            "name": "support.class.litescript",
            "match": "\\b\\w+;"
        },
        {
            "name": "variable.other.litescript",
            "match": "\\b[A-Za-z_][\\w]*\\b"
        }
    ]
}