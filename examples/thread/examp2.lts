import thread io

worker
	N = arg0

	id = 0
	thread_id; id
	nt = 0
	num_threads; nt
	BS = N / nt
	begin = id*BS
	fin = (id+1)*BS
	local_counter = 0
	loop begin < fin
		local_counter += 1
		begin += 1
	lock_mutex; 0
	counter += local_counter
	unlock_mutex; 0

start
	global counter
	counter = 0
	N = 1 << 23
	P = 0
	num_cores; P
	parallel; P worker: N
	display; counter "\n"

$ BENCHMARKS
$ Sequential: ~10s
$ Parallel: ~3s