import thread io

worker
	N = arg0
	id = 0
	thread_id; id
	nt = 0
	num_threads; nt
	BS = N / nt
	idx = id*BS
	fin = (id+1)*BS
	loop idx < fin
		lock_mutex; 0
		globalContainer put idx <- 1
		unlock_mutex; 0
		idx += 1

start
	global globalContainer
	container globalContainer
	N = 1 << 13
	i = 0
	loop i < N
		globalContainer put i <- 0
		i += 1

	parallel; 4 worker: N